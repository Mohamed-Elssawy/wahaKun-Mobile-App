{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["assets/*"]
    }
  },
  "include": ["src/**/*", "__tests__/**/*", "App.tsx", "declarations.d.ts"],
  "exclude": ["**/node_modules", "**/Pods", "**/build"]
}
